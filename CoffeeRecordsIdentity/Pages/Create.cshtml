@page
@model CoffeeRecordsIdentity.Pages.CreateModel
@{
    ViewData["Title"] = "Přidat kávu";
}

<h1>Přidat záznam o kávě</h1>

<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="Input.MachineNo" class="control-label">Číslo kávovaru</label>
                <input asp-for="Input.MachineNo" class="form-control" />
                <span asp-validation-for="Input.MachineNo" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input type="submit" value="Přidat" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="./Index">Zpět na seznam</a>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}